generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  role         Role
  password     String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  actions      AuditLog[]
  transactions Transaction[]
  outlets      Outlet[]      @relation("OutletToUser")
  stockLedger  StockLedger[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Warehouse {
  id                String        @id @default(cuid())
  name              String
  address           String?
  state             String?
  contactName       String?
  contactPhone      String?
  stocks            Stock[]
  outlets           Outlet[]      @relation("OutletToWarehouse")
  batches           CustomBatch[]
  stockLedger       StockLedger[]
  outboundTransfers Transaction[] @relation("FromWarehouse")
  inboundTransfers  Transaction[] @relation("ToWarehouse")
}

model Outlet {
  id                    String           @id @default(cuid())
  name                  String
  address               String?
  state                 String?
  invoicePrefix         String
  invoiceStartingNumber Int              @default(1)
  gstin                 String?
  bankDetails           String?
  defaultWarehouseId    String?
  negativeStockPolicy   String           @default("WARN")
  batchTrackingEnabled  Boolean          @default(false)
  stocks                Stock[]
  users                 User[]           @relation("OutletToUser")
  warehouses            Warehouse[]      @relation("OutletToWarehouse")
  categories            Category[]
  products              Product[]
  transactions          Transaction[]
  parties               Party[]
  accounts              Account[]
  variants              Variant[]
  series                DocumentSeries[]
  batches               CustomBatch[]
  stockLedger           StockLedger[]
}

model Category {
  id             String     @id @default(cuid())
  name           String
  parentId       String?
  parent         Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryHierarchy")
  products       Product[]
  parentProducts Product[]  @relation("ProductParentCategory")
  variants       Variant[]
  description    String?
  isActive       Boolean    @default(true)
  outletId       String
  outlet         Outlet     @relation(fields: [outletId], references: [id])

  @@unique([name, outletId])
}

model Product {
  id               String    @id @default(cuid())
  name             String
  brand            String?
  hsnCode          String
  gstRate          Float
  baseUnit         String
  purchaseUnit     String?
  salesUnit        String?
  conversionRatio  Float?    @default(1)
  categoryId       String
  isArchived       Boolean   @default(false)
  parentCategoryId String?
  category         Category  @relation(fields: [categoryId], references: [id])
  parentCategory   Category? @relation("ProductParentCategory", fields: [parentCategoryId], references: [id])
  variants         Variant[]
  outletId         String
  outlet           Outlet    @relation(fields: [outletId], references: [id])

  @@unique([name, outletId])
}

model Variant {
  id               String            @id @default(cuid())
  productId        String
  sku              String
  specifications   Json?
  purchasePrice    Float
  sellingPrice     Float
  pricingMethod    String            @default("MANUAL")
  markupPercent    Float?
  minStockLevel    Float             @default(0)
  categoryId       String
  outletId         String
  priceListEntries PriceListEntry[]
  stocks           Stock[]
  txnItems         TransactionItem[]
  batches          CustomBatch[]
  stockLedger      StockLedger[]
  category         Category          @relation(fields: [categoryId], references: [id])
  product          Product           @relation(fields: [productId], references: [id])
  outlet           Outlet            @relation(fields: [outletId], references: [id])
  suppliers        VendorProduct[]

  @@unique([sku, outletId])
}

model Stock {
  id           String     @id @default(cuid())
  variantId    String
  warehouseId  String?
  outletId     String?
  quantity     Float      @default(0)
  inTransitQty Float      @default(0)
  outlet       Outlet?    @relation(fields: [outletId], references: [id])
  variant      Variant    @relation(fields: [variantId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([variantId, warehouseId, outletId])
}

model Party {
  id               String          @id @default(cuid())
  type             PartyType
  name             String
  gstin            String?
  pan              String?
  address          String
  state            String
  contactInfo      String?
  creditPeriod     Int             @default(0)
  creditLimit      Float?
  openingBalance   Float           @default(0)
  priceListId      String?
  outletId         String
  outlet           Outlet          @relation(fields: [outletId], references: [id])
  ledgerEntries    LedgerEntry[]
  priceList        PriceList?      @relation(fields: [priceListId], references: [id])
  transactions     Transaction[]
  suppliedProducts VendorProduct[]
}

model Transaction {
  id             String            @id @default(cuid())
  type           TxType
  txnNumber      String            @unique
  date           DateTime          @default(now())
  partyId        String?
  outletId       String // Scoping to outlet
  fromLocationId String?
  toLocationId   String?
  totalTaxable   Float             @default(0)
  totalTax       Float             @default(0)
  freightCost    Float?            @default(0)
  grandTotal     Float             @default(0)
  status         String            @default("DRAFT")
  parentId       String?
  userId         String
  remarks        String?
  ledgerEntries  LedgerEntry[]
  parent         Transaction?      @relation("TxFlow", fields: [parentId], references: [id])
  children       Transaction[]     @relation("TxFlow")
  party          Party?            @relation(fields: [partyId], references: [id])
  outlet         Outlet            @relation(fields: [outletId], references: [id])
  fromWarehouse  Warehouse?        @relation("FromWarehouse", fields: [fromLocationId], references: [id])
  toWarehouse    Warehouse?        @relation("ToWarehouse", fields: [toLocationId], references: [id])
  user           User              @relation(fields: [userId], references: [id])
  items          TransactionItem[]
  batchMovements BatchMovement[]
  stockLedger    StockLedger[]
}

model TransactionItem {
  id              String      @id @default(cuid())
  transactionId   String
  variantId       String
  quantity        Float
  unit            String? // Captured unit (Base or Purchase)
  conversionRatio Float?      @default(1) // Ratio at time of transaction
  rate            Float
  freightFraction Float?
  taxableValue    Float
  cgst            Float       @default(0)
  sgst            Float       @default(0)
  igst            Float       @default(0)
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  variant         Variant     @relation(fields: [variantId], references: [id])
}

model Account {
  id       String        @id @default(cuid())
  code     String
  name     String
  group    AccountGroup
  isSystem Boolean       @default(false)
  outletId String
  outlet   Outlet        @relation(fields: [outletId], references: [id])
  entries  LedgerEntry[]

  @@unique([code, outletId])
}

model LedgerEntry {
  id            String       @id @default(cuid())
  accountId     String
  partyId       String?
  transactionId String?
  date          DateTime     @default(now())
  debit         Float        @default(0)
  credit        Float        @default(0)
  reference     String?
  isReconciled  Boolean      @default(false)
  account       Account      @relation(fields: [accountId], references: [id])
  party         Party?       @relation(fields: [partyId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
}

model VendorProduct {
  id        String  @id @default(cuid())
  vendorId  String
  variantId String
  lastPrice Float?
  leadTime  Int?
  variant   Variant @relation(fields: [variantId], references: [id])
  vendor    Party   @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, variantId])
}

model PriceList {
  id          String           @id @default(cuid())
  name        String
  description String?
  isActive    Boolean          @default(true)
  parties     Party[]
  entries     PriceListEntry[]
}

model DocumentSeries {
  id            String   @id @default(cuid())
  type          String // INV, PO, GRN, TRF, ADJ
  prefix        String
  nextNumber    Int      @default(1)
  financialYear String
  outletId      String
  outlet        Outlet   @relation(fields: [outletId], references: [id])
  updatedAt     DateTime @updatedAt

  @@unique([type, financialYear, outletId])
}

model CustomBatch {
  id               String          @id @default(cuid())
  batchNumber      String          @unique
  variantId        String
  warehouseId      String
  outletId         String
  receivedDate     DateTime        @default(now())
  quantityReceived Float
  quantityConsumed Float           @default(0)
  costPerUnit      Float
  variant          Variant         @relation(fields: [variantId], references: [id])
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id])
  outlet           Outlet          @relation(fields: [outletId], references: [id])
  movements        BatchMovement[]
  createdAt        DateTime        @default(now())

  @@index([variantId, warehouseId, receivedDate])
}

model BatchMovement {
  id            String      @id @default(cuid())
  batchId       String
  transactionId String
  quantity      Float // Positive for in, negative for out
  date          DateTime    @default(now())
  batch         CustomBatch @relation(fields: [batchId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model StockLedger {
  id            String      @id @default(cuid())
  variantId     String
  warehouseId   String
  outletId      String
  transactionId String
  date          DateTime    @default(now())
  quantity      Float // Net movement
  balance       Float // Running balance after this entry
  type          String // PURCHASE, SALE, TRANSFER, ADJUSTMENT
  userId        String
  variant       Variant     @relation(fields: [variantId], references: [id])
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  outlet        Outlet      @relation(fields: [outletId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@index([variantId, warehouseId, date])
}

model PriceListEntry {
  id          String    @id @default(cuid())
  priceListId String
  variantId   String
  price       Float
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant     Variant   @relation(fields: [variantId], references: [id])

  @@unique([priceListId, variantId])
}

enum Role {
  ADMIN
  ACCOUNTANT
  SALES
  INVENTORY_MANAGER
}

enum PartyType {
  VENDOR
  CUSTOMER
}

enum TxType {
  PURCHASE_ORDER
  GRN
  PURCHASE_BILL
  DEBIT_NOTE
  PROFORMA_INVOICE
  DELIVERY_CHALLAN
  SALES_INVOICE
  CREDIT_NOTE
  STOCK_TRANSFER
  STOCK_ADJUSTMENT
  QUOTATION
  PURCHASE_REQUEST
}

enum AccountGroup {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}
